prototype(SJS.Neos.MCP:Module.Connection.Action.Edit) < prototype(Neos.Fusion:Component) {
    connection = ${connection}
    accounts = ${accounts}

    renderer = afx`
        <SJS.Neos.MCP:Module.Component.Connection.Edit
            connection={props.connection}
            accounts={props.accounts}
            showAccount={true}
            cancelAction="party"
            cancelArguments={{party: props.connection.party}}
        />
    `
}
