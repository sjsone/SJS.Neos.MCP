prototype(SJS.Neos.MCP:Module.Connection.Action.New) < prototype(Neos.Fusion:Component) {
    accounts = ${accounts}
    party = ${party}

    renderer = afx`
        <SJS.Neos.MCP:Module.Component.Connection.New
            party={props.party}
            accounts={props.accounts}
            showAccount={true}
        />
    `
}
